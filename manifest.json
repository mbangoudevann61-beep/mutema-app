<!DOCTYPE html>
<html lang="fr">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0, user-scalable=no">
<title>MUTEMA — 2026 Cloud</title>
<link href="https://fonts.googleapis.com/css2?family=Bebas+Neue&family=DM+Sans:wght@400;500;700&family=JetBrains+Mono:wght@400;700&display=swap" rel="stylesheet">
<link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
<style>
  :root {
    --gold: #f5c842; --emerald: #10d98f; --red: #ff4757; --blue: #3a86ff;
    --blue-deep: #004a99; --bg: #050c14; --bg2: #0a1622;
    --text: #e8f0fe; --text-dim: rgba(232,240,254,0.45);
  }
  * { box-sizing: border-box; margin: 0; padding: 0; }
  body { font-family: 'DM Sans', sans-serif; background: var(--bg); color: var(--text); padding-bottom: 110px; overflow-x: hidden; }

  /* ── HEADER ANIMÉ ── */
  .hero {
    position: relative; background: linear-gradient(180deg, var(--blue-deep) 0%, var(--bg) 100%);
    height: 180px; display: flex; flex-direction: column; align-items: center; justify-content: center;
    overflow: hidden; border-bottom: 1px solid var(--gold);
  }
  .logo-main { font-family: 'Bebas Neue', sans-serif; font-size: 55px; letter-spacing: 6px; background: linear-gradient(135deg, #f5c842, #fff7c2); -webkit-background-clip: text; -webkit-text-fill-color: transparent; z-index: 10; }
  
  .cloud { position: absolute; background: white; border-radius: 50px; opacity: 0.1; animation: moveClouds linear infinite; z-index: 1; }
  .cloud1 { width: 100px; height: 40px; top: 20px; animation-duration: 25s; left:-120px; }
  .cloud2 { width: 60px; height: 20px; top: 80px; animation-duration: 18s; opacity: 0.05; left:-100px; }
  @keyframes moveClouds { from { left: -120px; } to { left: 100%; } }

  .flower { position: absolute; color: rgba(245, 200, 66, 0.1); animation: floatFlow 6s infinite linear; z-index: 2; }
  @keyframes floatFlow { 0% { transform: translateY(180px) rotate(0deg); opacity:0; } 50% { opacity:1; } 100% { transform: translateY(-20px) rotate(360deg); opacity:0; } }

  .wave { position: absolute; bottom: 0; width: 200%; height: 40px; background: url('https://raw.githubusercontent.com/front-end-relative/waves-animation/master/wave.png'); background-size: 50% 40px; animation: wave-move 10s linear infinite; opacity: 0.2; z-index: 3; }
  @keyframes wave-move { 0% { transform: translateX(0); } 100% { transform: translateX(-50%); } }

  /* ── SYNC STATUS ── */
  .sync-bar { display: flex; align-items: center; gap: 8px; font-size: 10px; padding: 6px 15px; background: rgba(255,255,255,0.03); border-bottom: 1px solid rgba(255,255,255,0.05); }
  .sync-dot { width: 8px; height: 8px; border-radius: 50%; background: var(--emerald); animation: pulse 2s infinite; }
  .sync-dot.offline { background: var(--red); animation: none; }
  .sync-dot.syncing { background: var(--gold); }
  @keyframes pulse { 0%,100%{opacity:1} 50%{opacity:0.3} }

  /* ── NAVIGATION ── */
  nav { position: fixed; bottom: 0; left: 0; right: 0; z-index: 1000; background: #050c14; border-top: 1px solid var(--gold); display: flex; justify-content: space-around; padding: 12px 0; }
  .nav-btn { background: none; border: none; color: var(--text-dim); display: flex; flex-direction: column; align-items: center; font-size: 7px; cursor: pointer; font-weight: bold; text-transform: uppercase; }
  .nav-btn i { font-size: 18px; margin-bottom: 4px; }
  .nav-btn.active { color: var(--gold); }

  /* ── TABS ── */
  .tab { display: none; padding: 15px; max-width: 500px; margin: 0 auto; animation: fadeIn 0.3s ease; }
  .tab.active { display: block; }
  @keyframes fadeIn { from{opacity:0} to{opacity:1} }
  .card { background: var(--bg2); border: 1px solid rgba(255,255,255,0.05); border-radius: 12px; padding: 15px; margin-bottom: 12px; }
  .sec-title { font-family: 'Bebas Neue', sans-serif; font-size: 22px; color: var(--gold); margin-bottom: 10px; border-bottom: 1px solid rgba(255,255,255,0.1); padding-bottom: 5px; }

  /* ── BADGES ── */
  .badge { font-family: 'JetBrains Mono', monospace; font-size: 7px; padding: 3px 6px; border-radius: 4px; margin: 2px; display: inline-block; font-weight: bold; }
  .badge-noire { background: rgba(245,200,66,0.15); color: var(--gold); border: 1px solid var(--gold); }
  .badge-epargne { background: rgba(16,217,143,0.15); color: var(--emerald); border: 1px solid var(--emerald); }
  .badge-deces { background: rgba(255,71,87,0.15); color: var(--red); border: 1px solid var(--red); }
  .badge-solidarite { background: rgba(58,134,255,0.15); color: var(--blue); border: 1px solid var(--blue); }

  .msg-bubble { background: #1a2a3a; border-radius: 12px; padding: 10px; margin-bottom: 8px; font-size: 12px; border-left: 3px solid var(--blue); }
  .msg-time { font-size: 9px; color: var(--text-dim); margin-top: 4px; }

  /* ── MODAL ── */
  .modal { position: fixed; inset: 0; background: rgba(0,0,0,0.9); display: none; align-items: center; justify-content: center; z-index: 2000; }
  .modal.active { display: flex; }
  .modal-box { background: var(--bg2); padding: 25px; border-radius: 15px; border: 1px solid var(--gold); width: 280px; text-align: center; }
  
  input, select, textarea { width: 100%; padding: 10px; background: #050c14; border: 1px solid #333; color: white; border-radius: 5px; margin-top: 8px; font-size: 13px; }
  .btn { width: 100%; padding: 12px; border-radius: 5px; border: none; font-weight: bold; cursor: pointer; margin-top: 10px; text-transform: uppercase; font-size: 10px; }
  .btn-gold { background: var(--gold); color: black; }

  /* ── REFRESH BTN ── */
  .refresh-btn { background: none; border: 1px solid var(--gold); color: var(--gold); border-radius: 6px; padding: 4px 10px; font-size: 10px; cursor: pointer; margin-left: auto; }
</style>
</head>
<body>

<header class="hero">
  <div class="cloud cloud1"></div>
  <div class="cloud cloud2"></div>
  <div id="flower-zone"></div>
  <div class="logo-main">MUTEMA</div>
  <div style="font-size:8px; color:var(--gold); letter-spacing:3px; z-index:10; font-weight:bold">RIGUEUR • DISCIPLINE • ENTRAIDE</div>
  <div class="wave"></div>
</header>

<!-- Barre de statut sync -->
<div class="sync-bar">
  <div class="sync-dot" id="syncDot"></div>
  <span id="statusText">Connexion au Cloud...</span>
  <button class="refresh-btn" onclick="loadFromGitHub()"><i class="fas fa-sync-alt"></i> Sync</button>
</div>

<main>
  <div class="tab active" id="tab-home">
    <div class="sec-title"><i class="fas fa-wallet"></i> État des Cotisations</div>
    <div id="financeList"></div>
  </div>

  <div class="tab" id="tab-projets">
    <div class="sec-title"><i class="fas fa-tasks"></i> Projets</div>
    <div id="projectList"></div>
    <button class="btn btn-gold" onclick="openSec('projet')">Nouveau Projet</button>
  </div>

  <div class="tab" id="tab-messages">
    <div class="sec-title"><i class="fas fa-comments"></i> Discussion</div>
    <textarea id="freeInput" placeholder="Écrire aux membres..." rows="3"></textarea>
    <button class="btn btn-gold" style="background:var(--blue); color:white" onclick="postFree()">Envoyer</button>
    <div id="freeList" style="margin-top:15px"></div>
  </div>

  <div class="tab" id="tab-admin">
    <div class="sec-title"><i class="fas fa-key"></i> Gestion Administrateur</div>
    <div class="card">
        <label style="font-size:11px; color:var(--text-dim)">Membre</label>
        <select id="aM"></select>
        <label style="font-size:11px; color:var(--text-dim); margin-top:8px; display:block">Type de cotisation</label>
        <select id="aType">
          <option value="noire">Caisse Noire</option>
          <option value="epargne">Épargne</option>
          <option value="deces">Décès</option>
          <option value="solidarite">Solidarité</option>
        </select>
        <label style="font-size:11px; color:var(--text-dim); margin-top:8px; display:block">Mois</label>
        <select id="aMonth">
          <option>Janvier</option><option>Février</option><option>Mars</option>
          <option>Avril</option><option>Mai</option><option>Juin</option>
          <option>Juillet</option><option>Août</option><option>Septembre</option>
          <option>Octobre</option><option>Novembre</option><option>Décembre</option>
        </select>
        <button class="btn btn-gold" onclick="addPay()"><i class="fas fa-check"></i> Valider le versement</button>
    </div>
    <div class="sec-title" style="font-size:16px; margin-top:10px">Historique</div>
    <div id="adminPayList"></div>
  </div>
</main>

<nav>
  <button class="nav-btn active" onclick="showTab('home', this)"><i class="fas fa-home"></i><span>Home</span></button>
  <button class="nav-btn" onclick="showTab('projets', this)"><i class="fas fa-project-diagram"></i><span>Projet</span></button>
  <button class="nav-btn" onclick="showTab('messages', this)"><i class="fas fa-comment-dots"></i><span>Message</span></button>
  <button class="nav-btn" onclick="openSec('admin', this)"><i class="fas fa-user-shield"></i><span>Gestion</span></button>
</nav>

<div class="modal" id="secModal">
  <div class="modal-box">
    <h4 style="color:var(--gold); margin-bottom:5px">🔐 CODE D'ACCÈS</h4>
    <p style="font-size:10px; color:var(--text-dim)">Réservé aux administrateurs</p>
    <input type="password" id="secKey" placeholder="Entrez le code" onkeydown="if(event.key==='Enter') checkKey()">
    <button class="btn btn-gold" onclick="checkKey()">Valider</button>
    <button class="btn" style="background:none; color:var(--text-dim); border:1px solid #333" onclick="closeSec()">Annuler</button>
  </div>
</div>

<script>
// ══════════════════════════════════════════
// CONFIGURATION CLOUD — NE PAS MODIFIER
// ══════════════════════════════════════════
const GH_TOKEN   = "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";
const GH_GIST_ID = "59930b7105c13306917098cd97a8312f";
const API_URL    = `https://api.github.com/gists/${GH_GIST_ID}`;
const HEADERS    = { "Authorization": `token ${GH_TOKEN}`, "Content-Type": "application/json" };

const MEMBERS = [
  "Kamara","Bermine","Caprisse Auderey","Devann","Carol Charonne",
  "Achille","Syntiche Promesse","Aurnelia","Alicia Carolle","Carmela","Jolene","Éric Didier"
];

let db = { payments: [], mur: [], messages: [], projets: [] };
let curAction = null;
let autoRefreshInterval = null;

// ══════════════════════════════════════════
// SYNC CLOUD — LECTURE & ÉCRITURE
// ══════════════════════════════════════════
function setSyncStatus(state, msg) {
  const dot = document.getElementById('syncDot');
  const txt = document.getElementById('statusText');
  dot.className = 'sync-dot' + (state === 'ok' ? '' : state === 'syncing' ? ' syncing' : ' offline');
  txt.textContent = msg;
}

async function loadFromGitHub() {
  setSyncStatus('syncing', '⏳ Synchronisation...');
  try {
    const r = await fetch(API_URL + '?t=' + Date.now(), { headers: HEADERS });
    if (!r.ok) throw new Error('HTTP ' + r.status);
    const data = await r.json();
    const content = data.files["mutema_db.json"]?.content;
    if (!content) throw new Error('Fichier vide');
    db = JSON.parse(content);
    // S'assurer que toutes les clés existent
    if (!db.payments) db.payments = [];
    if (!db.messages) db.messages = [];
    if (!db.projets)  db.projets  = [];
    if (!db.mur)      db.mur      = [];
    renderAll();
    setSyncStatus('ok', '✅ Cloud synchronisé — ' + new Date().toLocaleTimeString());
  } catch (e) {
    setSyncStatus('offline', '⚠️ Hors ligne — données locales');
    console.error('Load error:', e);
  }
}

async function saveToGitHub() {
  setSyncStatus('syncing', '⏳ Sauvegarde...');
  try {
    const res = await fetch(API_URL, {
      method: "PATCH",
      headers: HEADERS,
      body: JSON.stringify({ files: { "mutema_db.json": { content: JSON.stringify(db) } } })
    });
    if (!res.ok) throw new Error('HTTP ' + res.status);
    setSyncStatus('ok', '✅ Sauvegardé — ' + new Date().toLocaleTimeString());
    renderAll();
  } catch (e) {
    setSyncStatus('offline', '❌ Erreur de sauvegarde');
    console.error('Save error:', e);
  }
}

// Auto-refresh toutes les 15 secondes (temps réel multi-appareils)
function startAutoRefresh() {
  if (autoRefreshInterval) clearInterval(autoRefreshInterval);
  autoRefreshInterval = setInterval(loadFromGitHub, 15000);
}

// ══════════════════════════════════════════
// ANIMATIONS
// ══════════════════════════════════════════
function spawnF() {
  const f = document.createElement('i');
  f.className = 'fas fa-fan flower';
  f.style.cssText = `position:absolute;left:${Math.random()*100}vw;color:rgba(245,200,66,0.1);animation:floatFlow 6s linear;bottom:0;z-index:2;font-size:${10+Math.random()*15}px`;
  document.getElementById('flower-zone').appendChild(f);
  setTimeout(() => f.remove(), 6000);
}
setInterval(spawnF, 2000);

// ══════════════════════════════════════════
// NAVIGATION
// ══════════════════════════════════════════
function showTab(id, btn) {
  document.querySelectorAll('.tab').forEach(t => t.classList.remove('active'));
  document.querySelectorAll('.nav-btn').forEach(n => n.classList.remove('active'));
  document.getElementById('tab-'+id).classList.add('active');
  if (btn) btn.classList.add('active');
}

function openSec(act, btn) {
  curAction = { act, btn };
  document.getElementById('secKey').value = '';
  document.getElementById('secModal').classList.add('active');
  setTimeout(() => document.getElementById('secKey').focus(), 100);
}
function closeSec() { document.getElementById('secModal').classList.remove('active'); }

function checkKey() {
  const k = document.getElementById('secKey').value;
  if (k === "1604" || k === "2026") {
    closeSec();
    if (curAction.act === 'admin') showTab('admin', curAction.btn);
    if (curAction.act === 'projet') {
      const t = prompt("Titre du projet :");
      if (t) { db.projets.unshift({ id: Date.now(), title: t }); saveToGitHub(); }
    }
  } else {
    document.getElementById('secKey').style.border = '1px solid var(--red)';
    setTimeout(() => document.getElementById('secKey').style.border = '1px solid #333', 1000);
    alert("❌ Accès refusé.");
  }
}

// ══════════════════════════════════════════
// ACTIONS DONNÉES
// ══════════════════════════════════════════
function addPay() {
  const p = {
    id: Date.now(),
    name: document.getElementById('aM').value,
    type: document.getElementById('aType').value,
    month: document.getElementById('aMonth').value,
    date: new Date().toLocaleDateString('fr-FR')
  };
  db.payments.unshift(p);
  saveToGitHub();
}

function deletePay(id) {
  if (confirm("Supprimer ce versement ?")) {
    db.payments = db.payments.filter(x => x.id !== id);
    saveToGitHub();
  }
}

function deleteMsg(idx) {
  if (confirm("Supprimer ce message ?")) {
    db.messages.splice(idx, 1);
    saveToGitHub();
  }
}

function deleteProjet(id) {
  if (confirm("Supprimer ce projet ?")) {
    db.projets = db.projets.filter(x => x.id !== id);
    saveToGitHub();
  }
}

function postFree() {
  const v = document.getElementById('freeInput').value.trim();
  if (v) {
    db.messages.unshift({ text: v, time: new Date().toLocaleString('fr-FR') });
    document.getElementById('freeInput').value = "";
    saveToGitHub();
  }
}

// ══════════════════════════════════════════
// RENDU INTERFACE
// ══════════════════════════════════════════
function renderAll() {
  // ── Cotisations par membre
  document.getElementById('financeList').innerHTML = MEMBERS.map(m => {
    const pays = db.payments.filter(x => x.name === m);
    const total = pays.length;
    return `
      <div class="card">
        <div style="display:flex; justify-content:space-between; align-items:center; margin-bottom:6px">
          <b style="font-size:13px">${m}</b>
          <span style="font-size:9px; color:var(--text-dim)">${total} versement${total !== 1 ? 's' : ''}</span>
        </div>
        <div>${pays.length
          ? pays.map(v => `<span class="badge badge-${v.type}">${v.month.substring(0,3)} • ${v.type.toUpperCase()}</span>`).join('')
          : `<span style="font-size:10px; color:var(--text-dim)">Aucun versement enregistré</span>`
        }</div>
      </div>`;
  }).join('');

  // ── Messages
  document.getElementById('freeList').innerHTML = db.messages.length
    ? db.messages.map((m, i) => `
        <div class="msg-bubble">
          <div>${m.text}</div>
          <div style="display:flex; justify-content:space-between; align-items:center; margin-top:6px">
            <span class="msg-time">🕒 ${m.time || ''}</span>
            <i class="fas fa-trash" onclick="deleteMsg(${i})" style="color:var(--red); font-size:10px; cursor:pointer"></i>
          </div>
        </div>`)
        .join('')
    : `<p style="font-size:11px; color:var(--text-dim); text-align:center; margin-top:20px">Aucun message pour l'instant</p>`;

  // ── Projets
  document.getElementById('projectList').innerHTML = db.projets.length
    ? db.projets.map(p => `
        <div class="card" style="display:flex; justify-content:space-between; align-items:center">
          <span>🚀 ${p.title}</span>
          <i class="fas fa-trash" onclick="deleteProjet(${p.id})" style="color:var(--red); cursor:pointer; font-size:12px"></i>
        </div>`).join('')
    : `<p style="font-size:11px; color:var(--text-dim); text-align:center; margin-top:20px">Aucun projet enregistré</p>`;

  // ── Admin : historique versements
  document.getElementById('adminPayList').innerHTML = db.payments.length
    ? db.payments.map(p => `
        <div class="card" style="display:flex; justify-content:space-between; align-items:center; font-size:11px">
          <div>
            <b>${p.name}</b>
            <span class="badge badge-${p.type}" style="margin-left:6px">${p.type.toUpperCase()}</span>
            <div style="color:var(--text-dim); font-size:9px; margin-top:3px">${p.month} ${p.date ? '• ' + p.date : ''}</div>
          </div>
          <i class="fas fa-trash" onclick="deletePay(${p.id})" style="color:var(--red); cursor:pointer"></i>
        </div>`).join('')
    : `<p style="font-size:11px; color:var(--text-dim); text-align:center">Aucun versement enregistré</p>`;
}

// ══════════════════════════════════════════
// INITIALISATION
// ══════════════════════════════════════════
window.onload = () => {
  document.getElementById('aM').innerHTML = MEMBERS.map(m => `<option>${m}</option>`).join('');
  loadFromGitHub();
  startAutoRefresh(); // Refresh auto toutes les 15s pour le temps réel
};
</script>
</body>
</html>
